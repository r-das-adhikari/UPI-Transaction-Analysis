    <worksheet name='Top 5 merchants by volume '>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontsize='11'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Transactions Model' name='federated.0rhq27f0kg3e8d12m7mkd1w927np' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Region Filter' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;west&quot;'>
              <calculation class='tableau' formula='&quot;west&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0rhq27f0kg3e8d12m7mkd1w927np'>
            <column caption='Failure Rate %' datatype='real' name='[Calculation_0771046102847488]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [status] = &apos;failed&apos; THEN 1 ELSE 0 END)/COUNT([transaction_id])' />
            </column>
            <column caption='Fraud Rate %' datatype='real' name='[Calculation_0771046103609345]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [fraud_flag]= TRUE THEN 1 ELSE 0 END)/COUNT([transaction_id])' />
            </column>
            <column caption='Reversal Rate %' datatype='real' name='[Calculation_0771046104608770]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [reversal_flag]=TRUE THEN 1 ELSE 0 END)/COUNT([transaction_id])' />
            </column>
            <column caption='AVG(0)' datatype='real' name='[Calculation_0839490955919364]' role='measure' type='quantitative' user:unnamed='Top 10 merchants by volume (horizontal bar)'>
              <calculation class='tableau' formula='AVG(0)' />
            </column>
            <column caption='Hours' datatype='integer' name='[Calculation_0839491014082565]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, [timestamp])' />
            </column>
            <column caption='Region Match' datatype='boolean' name='[Calculation_1040702821875717]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Parameters].[Parameter 1]=&apos;(All)&apos; OR [region]= [Parameters].[Parameter 1]' />
            </column>
            <column caption='Resolution Hours' datatype='integer' name='[Calculation_1048123688976385]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&apos;hour&apos;,[alert_date],[resolution_date])' />
            </column>
            <column caption='Resolved Percentage' datatype='integer' name='[Calculation_1262803694866432]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='INT([resolved])' />
            </column>
            <column caption='% Rooted Transactions' datatype='real' default-format='p0.00%' name='[Calculation_1262803697217537]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [is_rooted] THEN 1 ELSE 0 END)/COUNT([transaction_id])' />
            </column>
            <column caption='Is Stale Pending' datatype='integer' name='[Calculation_1262803697881090]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [status]=&apos;pending&apos; AND DATEDIFF(&apos;day&apos;,[timestamp],TODAY())&gt; 30 THEN 1 ELSE 0 END' />
            </column>
